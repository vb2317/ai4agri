# AI4Agri local/remote environment template.
# Copy to .env on a machine that needs these values. Do not commit .env.

# Optional: Hugging Face token, only needed if data access requires auth.
HF_TOKEN=

# Data roots. Keep raw data outside git-tracked files.
AI4AGRI_DATA_DIR=./data
AI4AGRI_SUBTASK1_DATA_DIR=./data/subtask1
AI4AGRI_SUBTASK2_DATA_DIR=./data/subtask2

# Output roots.
AI4AGRI_RESULTS_DIR=./results
AI4AGRI_RUNS_CSV=./results/runs.csv

# Remote sync placeholders. Fill these per provider/machine.
AI4AGRI_REMOTE_HOST=
AI4AGRI_REMOTE_USER=
AI4AGRI_REMOTE_PROJECT_DIR=
